generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                   @unique @db.VarChar(320)
  name                    String                   @db.VarChar(160)
  passwordHash            String?                  @map("password_hash") @db.VarChar(255)
  phone                   String?                  @unique @db.VarChar(32)
  image                   String?                  @db.VarChar(2048)
  status                  UserStatus               @default(ACTIVE)
  emailVerified           DateTime?                @map("email_verified") @db.Timestamptz(6)
  lastLoginAt             DateTime?                @map("last_login_at") @db.Timestamptz(6)
  createdAt               DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime                 @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt               DateTime?                @map("deleted_at") @db.Timestamptz(6)
  aiConversations         AIConversation[]
  auditLogs               AuditLog[]               @relation("AuditActor")
  carts                   Cart[]
  reviews                 CustomerReview[]
  emailVerificationTokens EmailVerificationToken[]
  notifications           Notification[]
  orders                  Order[]
  passwordResetTokens     PasswordResetToken[]
  roles                   Role[]                   @relation("RoleToUser")

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model EmailVerificationToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([deletedAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(128)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([deletedAt])
  @@map("password_reset_tokens")
}

model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(64)
  description String?   @db.VarChar(255)
  permissions Json      @default("[]")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  users       User[]    @relation("RoleToUser")

  @@index([deletedAt])
  @@map("roles")
}

model Category {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @db.VarChar(120)
  slug        String      @unique @db.VarChar(160)
  description String?
  imageUrl    String?     @map("image_url") @db.VarChar(2048)
  parentId    String?     @map("parent_id") @db.Uuid
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz(6)
  parent      Category?   @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryHierarchy")
  products    Product[]
  promotions  Promotion[] @relation("CategoryToPromotion")

  @@index([parentId])
  @@index([deletedAt])
  @@map("categories")
}

model Supplier {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @db.VarChar(180)
  contactName    String?         @map("contact_name") @db.VarChar(160)
  email          String?         @db.VarChar(320)
  phone          String?         @db.VarChar(32)
  addressLine1   String?         @map("address_line_1") @db.VarChar(180)
  addressLine2   String?         @map("address_line_2") @db.VarChar(180)
  city           String?         @db.VarChar(100)
  country        String?         @db.VarChar(100)
  taxId          String?         @map("tax_id") @db.VarChar(80)
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)
  products       Product[]
  stockMovements StockMovement[]

  @@unique([name, email])
  @@index([deletedAt])
  @@map("suppliers")
}

model Product {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId     String           @map("category_id") @db.Uuid
  supplierId     String?          @map("supplier_id") @db.Uuid
  name           String           @db.VarChar(180)
  slug           String           @unique @db.VarChar(220)
  sku            String           @unique @db.VarChar(80)
  barcode        String?          @unique @db.VarChar(80)
  description    String?
  imageUrl       String?          @map("image_url") @db.VarChar(2048)
  price          Decimal          @db.Decimal(12, 2)
  compareAtPrice Decimal?         @map("compare_at_price") @db.Decimal(12, 2)
  costPrice      Decimal?         @map("cost_price") @db.Decimal(12, 2)
  taxRate        Decimal          @default(0) @map("tax_rate") @db.Decimal(5, 2)
  weightGrams    Int?             @map("weight_grams")
  status         ProductStatus    @default(DRAFT)
  isFeatured     Boolean          @default(false) @map("is_featured")
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?        @map("deleted_at") @db.Timestamptz(6)
  cartItems      CartItem[]
  reviews        CustomerReview[]
  inventory      Inventory?
  orderItems     OrderItem[]
  category       Category         @relation(fields: [categoryId], references: [id])
  supplier       Supplier?        @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]
  promotions     Promotion[]      @relation("ProductToPromotion")

  @@index([categoryId, status])
  @@index([supplierId])
  @@index([status, deletedAt])
  @@index([isFeatured])
  @@map("products")
}

model Inventory {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId         String          @unique @map("product_id") @db.Uuid
  quantityOnHand    Int             @default(0) @map("quantity_on_hand")
  quantityReserved  Int             @default(0) @map("quantity_reserved")
  reorderLevel      Int             @default(10) @map("reorder_level")
  reorderQuantity   Int             @default(50) @map("reorder_quantity")
  warehouseLocation String?         @map("warehouse_location") @db.VarChar(120)
  status            InventoryStatus @default(IN_STOCK)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?       @map("deleted_at") @db.Timestamptz(6)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]

  @@index([status])
  @@index([deletedAt])
  @@map("inventories")
}

model Cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  status    CartStatus @default(ACTIVE)
  currency  String     @default("USD") @db.Char(3)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?  @map("deleted_at") @db.Timestamptz(6)
  items     CartItem[]
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([deletedAt])
  @@map("carts")
}

model CartItem {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String    @map("cart_id") @db.Uuid
  productId String    @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal   @map("unit_price") @db.Decimal(12, 2)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  cart      Cart      @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([productId])
  @@index([deletedAt])
  @@map("cart_items")
}

model Order {
  id                    String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber           String            @unique @map("order_number") @db.VarChar(40)
  userId                String            @map("user_id") @db.Uuid
  status                OrderStatus       @default(PENDING)
  paymentStatus         PaymentStatus     @default(PENDING) @map("payment_status")
  fulfillmentStatus     FulfillmentStatus @default(PENDING) @map("fulfillment_status")
  currency              String            @default("USD") @db.Char(3)
  subtotal              Decimal           @db.Decimal(12, 2)
  discountTotal         Decimal           @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal              Decimal           @default(0) @map("tax_total") @db.Decimal(12, 2)
  shippingTotal         Decimal           @default(0) @map("shipping_total") @db.Decimal(12, 2)
  grandTotal            Decimal           @map("grand_total") @db.Decimal(12, 2)
  shippingAddress       Json              @map("shipping_address")
  billingAddress        Json?             @map("billing_address")
  notes                 String?
  assignedSalespersonId String?           @map("assigned_salesperson_id") @db.Uuid
  createdAt             DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime?         @map("deleted_at") @db.Timestamptz(6)
  items                 OrderItem[]
  user                  User              @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status, paymentStatus])
  @@index([deletedAt])
  @@map("orders")
}

model OrderItem {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId       String    @map("order_id") @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  productName   String    @map("product_name") @db.VarChar(180)
  sku           String    @db.VarChar(80)
  quantity      Int
  unitPrice     Decimal   @map("unit_price") @db.Decimal(12, 2)
  discountTotal Decimal   @default(0) @map("discount_total") @db.Decimal(12, 2)
  taxTotal      Decimal   @default(0) @map("tax_total") @db.Decimal(12, 2)
  lineTotal     Decimal   @map("line_total") @db.Decimal(12, 2)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product   @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([deletedAt])
  @@map("order_items")
}

model Promotion {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String        @db.VarChar(160)
  code         String?       @unique @db.VarChar(64)
  description  String?
  type         PromotionType
  value        Decimal       @db.Decimal(12, 2)
  startsAt     DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime      @map("ends_at") @db.Timestamptz(6)
  usageLimit   Int?          @map("usage_limit")
  usageCount   Int           @default(0) @map("usage_count")
  minimumSpend Decimal?      @map("minimum_spend") @db.Decimal(12, 2)
  isActive     Boolean       @default(true) @map("is_active")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  categories   Category[]    @relation("CategoryToPromotion")
  products     Product[]     @relation("ProductToPromotion")

  @@index([isActive, startsAt, endsAt])
  @@index([deletedAt])
  @@map("promotions")
}

model Notification {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  channel   NotificationChannel
  status    NotificationStatus  @default(PENDING)
  title     String              @db.VarChar(180)
  body      String
  metadata  Json?
  sentAt    DateTime?           @map("sent_at") @db.Timestamptz(6)
  readAt    DateTime?           @map("read_at") @db.Timestamptz(6)
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?           @map("deleted_at") @db.Timestamptz(6)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([channel, status])
  @@index([deletedAt])
  @@map("notifications")
}

model CustomerReview {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  productId String       @map("product_id") @db.Uuid
  rating    Int
  title     String?      @db.VarChar(160)
  body      String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, status])
  @@index([rating])
  @@index([deletedAt])
  @@map("customer_reviews")
}

model StockMovement {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId   String            @map("product_id") @db.Uuid
  inventoryId String            @map("inventory_id") @db.Uuid
  supplierId  String?           @map("supplier_id") @db.Uuid
  type        StockMovementType
  quantity    Int
  unitCost    Decimal?          @map("unit_cost") @db.Decimal(12, 2)
  reference   String?           @db.VarChar(120)
  reason      String?           @db.VarChar(255)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?         @map("deleted_at") @db.Timestamptz(6)
  inventory   Inventory         @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id])
  supplier    Supplier?         @relation(fields: [supplierId], references: [id])

  @@index([productId, createdAt])
  @@index([inventoryId])
  @@index([supplierId])
  @@index([type])
  @@index([deletedAt])
  @@map("stock_movements")
}

model AIConversation {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String               @map("user_id") @db.Uuid
  status           AIConversationStatus @default(OPEN)
  provider         String               @default("openrouter") @db.VarChar(80)
  model            String               @db.VarChar(120)
  title            String?              @db.VarChar(180)
  messages         Json
  summary          String?
  promptTokens     Int?                 @map("prompt_tokens")
  completionTokens Int?                 @map("completion_tokens")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?            @map("deleted_at") @db.Timestamptz(6)
  user             User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([provider, model])
  @@index([deletedAt])
  @@map("ai_conversations")
}

model AuditLog {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityName String      @map("entity_name") @db.VarChar(120)
  entityId   String?     @map("entity_id") @db.Uuid
  oldValues  Json?       @map("old_values")
  newValues  Json?       @map("new_values")
  ipAddress  String?     @map("ip_address") @db.Inet
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?   @map("deleted_at") @db.Timestamptz(6)
  actor      User?       @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([entityName, entityId])
  @@index([action])
  @@index([deletedAt])
  @@map("audit_logs")
}

model Lead {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @db.VarChar(160)
  email        String    @db.VarChar(320)
  phone        String?   @db.VarChar(32)
  status       String    @default("NEW")
  value        Decimal?  @db.Decimal(12, 2)
  source       String?   @db.VarChar(100)
  notes        String?
  assignedToId String?   @map("assigned_to_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([status])
  @@index([assignedToId])
  @@index([deletedAt])
  @@map("leads")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum InventoryStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum CartStatus {
  ACTIVE
  ABANDONED
  CONVERTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum FulfillmentStatus {
  PENDING
  PICKING
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PromotionType {
  PERCENTAGE
  FIXED_AMOUNT
  BUY_X_GET_Y
  FREE_SHIPPING
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  READ
  FAILED
  CANCELLED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  HIDDEN
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  EXPIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  LOGIN
  LOGOUT
  PASSWORD_RESET
  ROLE_ASSIGN
  PERMISSION_DENIED
  EXPORT
}

enum AIConversationStatus {
  OPEN
  RESOLVED
  ESCALATED
  ARCHIVED
}
